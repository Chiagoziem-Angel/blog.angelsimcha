{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/series/:seriesId/:edition/:day",
      "destination": "/series-day.html?series=:seriesId&edition=:edition&day=:day"
    },
    {
      "source": "/series",
      "destination": "/series.html"
    },
    {
      "source": "/series-day",
      "destination": "/series-day.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/letter",
      "destination": "/letter.html"
    }
  ]
}